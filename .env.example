# ─────────────────────────────────────────────────────────────────────────────
# Photo & Video Analyzer — Docker environment variables
# Copy this file to .env and adjust as needed before running docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# Path to your photo/video library on the host (e.g. external SSD)
MEDIA_DIR=/Volumes/MySSD

# Ollama vision model to use (must already be pulled on the host)
# Recommended: llava (fast) or llama3.2-vision:90b (higher quality)
OLLAMA_MODEL=llava

# Number of key frames to sample per video file for LLM analysis (default: 5)
VIDEO_FRAMES=5
